generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id                    Int                @id @default(autoincrement())
  fullName              String
  gender                Gender
  dateOfBirth           DateTime           @default(now()) @db.Date
  rollNo                Int
  standard              String
  bloodGroup            String?
  scholarshipApplied    Boolean
  lunchAccepted         Boolean            @default(false)
  lunchPrice            Float?
  busAccepted           Boolean            @default(false)
  busStationId          Int?
  busPrice              Float?
  residentialAddress    String?
  correspondenceAddress String?
  photoUrl              String?
  remark                String?
  nationality           String?
  religion              String?
  denomination          String?
  language              String?
  motherTongue          String?
  status                StudentStatus      @default(None)
  session               String
  attendanceRecords     Attendance[]
  fees                  Fee[]
  marks                 Marks[]
  parents               Parent[]
  busStation            BusStation?        @relation(fields: [busStationId], references: [id])
  studentInventory      StudentInventory[]

  @@unique([standard, rollNo, session])
}

model Parent {
  id                   Int     @id @default(autoincrement())
  fatherName           String
  motherName           String
  fatherContact        BigInt
  motherContact        BigInt
  distanceFromSchool   Float?
  preferredPhoneNumber BigInt?
  address              String
  studentId            Int
  student              Student @relation(fields: [studentId], references: [id])
}

model Fee {
  id            Int      @id @default(autoincrement())
  title         String
  amount        Float
  amountDate    DateTime @default(now()) @db.Date
  admissionDate DateTime @default(now()) @db.Date
  studentId     Int
  student       Student  @relation(fields: [studentId], references: [id])
}

model Attendance {
  id          Int      @id @default(autoincrement())
  studentName String
  date        DateTime @default(now())
  status      Boolean
  rollNo      Int
  studentId   Int
  subjectId   Int?
  standard    String
  subjectName String?
  session     String
  student     Student  @relation(fields: [studentId], references: [id])
  subject     Subject? @relation(fields: [subjectId], references: [id])
}

model Marks {
  id              Int     @id @default(autoincrement())
  studentId       Int
  subjectId       Int
  subjectName     String
  examinationType String
  obtainedMarks   Float
  totalMarks      Float
  percentage      Float
  student         Student @relation(fields: [studentId], references: [id])
  subject         Subject @relation(fields: [subjectId], references: [id])

  @@unique([studentId, subjectId, examinationType])
}

model Hostel {
  id         Int    @id @unique @default(autoincrement())
  name       String
  rollNo     Int
  standard   String
  gender     String
  bed_number Int    @unique

  @@unique([rollNo, standard])
}

model Subject {
  id                Int          @id @default(autoincrement())
  name              String
  stdId             String
  attendanceRecords Attendance[]
  marks             Marks[]
  std               Standards    @relation(fields: [stdId], references: [std])
}

model Standards {
  id        Int       @unique @default(autoincrement())
  std       String    @unique
  category  String?
  totalFees Float?
  subjects  Subject[]
}

model Control {
  id                      Int      @id @default(autoincrement())
  sessionId               Int?     @unique
  number_of_hostel_bed    Int?
  Institution_name        String?  @default("School")
  Institution_hostel_name String?  @default("Hostel")
  SchoolLogo              String?
  SchoolAddress           String?
  TotalFees               Int?
  lunchFee                Float?
  session                 Session? @relation(fields: [sessionId], references: [id])
}

model Session {
  id        Int      @id @default(autoincrement())
  year      String   @unique
  createdAt DateTime @default(now())
  control   Control?
}

model Installments {
  id           Int    @id @default(autoincrement())
  installments String @unique
}

model Inventory {
  id               Int                @id @default(autoincrement())
  itemName         String
  category         String
  price            Float
  quantity         Int?
  size             String?
  description      String?
  gender           String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  studentInventory StudentInventory[]
}

model StudentInventory {
  id                Int       @id @default(autoincrement())
  studentId         Int
  inventoryId       Int
  quantityPurchased Int
  totalPrice        Float
  purchaseDate      DateTime  @default(now())
  inventory         Inventory @relation(fields: [inventoryId], references: [id])
  student           Student   @relation(fields: [studentId], references: [id])

  @@unique([studentId, inventoryId])
}

model BusStation {
  id          Int       @id @default(autoincrement())
  stationName String    @unique
  price       Float
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  students    Student[]
}

enum Gender {
  Male
  Female
}

enum StudentStatus {
  Passed
  Failed
  None
}
