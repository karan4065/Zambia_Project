generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id                 Int           @id @default(autoincrement())
  fullName           String
  gender             Gender
  dateOfBirth        DateTime      @default(now()) @db.Date
  rollNo             Int
  standard           String

  scholarshipApplied Boolean
  remark             String?
  address            String
  photoUrl           String?
  status             StudentStatus @default(None)
  session            String
  category           String
  caste              String
  attendanceRecords  Attendance[]
  fees               Fee[]
  marks              Marks[]
  parents            Parent[]

  @@unique([standard, rollNo, session])
}

model Parent {
  id               Int     @id @default(autoincrement())
  fatherName       String
  fatherOccupation String
  motherName       String
  motherOccupation String
  fatherContact    BigInt
  motherContact    BigInt
  address          String
  studentId        Int
  student          Student @relation(fields: [studentId], references: [id])
}

model Fee {
  id            Int      @id @default(autoincrement())
  title         String
  amount        Float
  amountDate    DateTime @default(now()) @db.Date
  admissionDate DateTime @default(now()) @db.Date
  studentId     Int
  student       Student  @relation(fields: [studentId], references: [id])
}

model Attendance {
  id          Int      @id @default(autoincrement())
  studentName String
  date        DateTime @default(now())
  status      Boolean
  rollNo      Int
  studentId   Int
  subjectId   Int?
  standard    String
  subjectName String?
  session     String
  student     Student  @relation(fields: [studentId], references: [id])
  subject     Subject? @relation(fields: [subjectId], references: [id])
}

model Marks {
  id              Int     @id @default(autoincrement())
  studentId       Int
  subjectId       Int
  subjectName     String
  examinationType String
  obtainedMarks   Float
  totalMarks      Float
  percentage      Float
  student         Student @relation(fields: [studentId], references: [id])
  subject         Subject @relation(fields: [subjectId], references: [id])

  @@unique([studentId, subjectId, examinationType])
}

model Hostel {
  id         Int    @id @unique @default(autoincrement())
  name       String
  rollNo     Int
  standard   String
  gender     String
  bed_number Int    @unique

  @@unique([rollNo, standard])
}

model Subject {
  id                Int          @id @default(autoincrement())
  name              String
  stdId             String
  attendanceRecords Attendance[]
  marks             Marks[]
  std               Standards    @relation(fields: [stdId], references: [std])
}

model Standards {
  id        Int       @unique @default(autoincrement())
  std       String    @unique
  category  String?
  totalFees Float?
  subjects  Subject[]
}

model Control {
  id                      Int     @id @default(autoincrement())
  sessionId               Int?
  session                 Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  number_of_hostel_bed    Int?
  Institution_name        String? @default("School")
  Institution_hostel_name String? @default("Hostel")
  SchoolLogo              String?
  SchoolAddress           String?
  TotalFees               Int?
  lunchFee                Float?

  @@unique([sessionId])
}

model Session {
  id        Int      @id @default(autoincrement())
  year      String   @unique
  control   Control?
  createdAt DateTime @default(now())
}

model Installments {
  id           Int    @id @default(autoincrement())
  installments String @unique
}

enum Gender {
  Male
  Female
}

enum StudentStatus {
  Passed
  Failed
  None
}

